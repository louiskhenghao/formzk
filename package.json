{
  "name": "formzk",
  "version": "0.0.1",
  "license": "MIT",
  "description": "A comprehensive form management library for React, integrating core functionalities with customizable UI components and advanced validation",
  "keywords": [
    "forms",
    "react",
    "form-management",
    "form-builder",
    "input-components",
    "ui-library",
    "react-hook-form",
    "material-ui",
    "validation"
  ],
  "author": "Louis Loo <louiskhenghao@gmail.com> (https://github.com/louiskhenghao)",
  "homepage": "https://github.com/louiskhenghao/formzk#readme",
  "scripts": {
    "start": "nx serve",
    "build": "nx build",
    "dep": "nx dep-graph",
    "format": "prettier --write .",
    "lint": "nx run-many --all --target=lint",
    "example:dev": "yarn start example --port=3333",
    "example:build": "yarn build example",
    "example:run": "yarn start example --prod --port=3333",
    "build:lib:core": "yarn build core",
    "build:lib:mui": "yarn build mui",
    "build:libs": "yarn build:lib:core && yarn build:lib:mui",
    "release": "yarn nx run formzk:version --releaseAs=patch && yarn build:libs",
    "release:minor": "yarn nx run formzk:version --releaseAs=minor && yarn build:libs",
    "release:major": "yarn nx run formzk:version --releaseAs=major && yarn build:libs"
  },
  "private": true,
  "dependencies": {
    "@emotion/react": "^11.11.4",
    "@emotion/styled": "^11.11.5",
    "@hookform/resolvers": "^3.7.0",
    "@mui/icons-material": "^5.15.21",
    "@mui/material": "^5.15.21",
    "next": "14.2.3",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-hook-form": "^7.52.1",
    "react-is": "18.3.1",
    "styled-components": "5.3.6",
    "tslib": "^2.3.0",
    "yup": "^1.4.0"
  },
  "devDependencies": {
    "@jscutlery/semver": "^5.2.2",
    "@nx/cypress": "19.2.3",
    "@nx/eslint": "19.2.3",
    "@nx/eslint-plugin": "19.2.3",
    "@nx/jest": "19.2.3",
    "@nx/js": "19.2.3",
    "@nx/next": "19.2.3",
    "@nx/rollup": "19.2.3",
    "@nx/workspace": "19.2.3",
    "@swc-node/register": "~1.9.1",
    "@swc/core": "~1.5.7",
    "@swc/helpers": "~0.5.11",
    "@swc/plugin-styled-components": "^1.5.67",
    "@testing-library/react": "15.0.6",
    "@types/jest": "^29.4.0",
    "@types/node": "18.16.9",
    "@types/react": "18.3.1",
    "@types/react-dom": "18.3.0",
    "@types/react-is": "18.3.0",
    "@types/styled-components": "5.1.26",
    "@typescript-eslint/eslint-plugin": "^7.3.0",
    "@typescript-eslint/parser": "^7.3.0",
    "babel-jest": "^29.4.1",
    "babel-plugin-styled-components": "1.10.7",
    "cypress": "^13.8.0",
    "eslint": "~8.57.0",
    "eslint-config-next": "14.2.3",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-cypress": "^2.13.4",
    "eslint-plugin-import": "2.27.5",
    "eslint-plugin-jsx-a11y": "6.7.1",
    "eslint-plugin-react": "7.32.2",
    "eslint-plugin-react-hooks": "4.6.0",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "jest": "^29.4.1",
    "jest-environment-jsdom": "^29.4.1",
    "nx": "19.2.3",
    "prettier": "^2.6.2",
    "ts-jest": "^29.1.0",
    "ts-node": "10.9.1",
    "typescript": "~5.4.2",
    "verdaccio": "^5.0.4"
  },
  "nx": {
    "includedScripts": []
  }
}
