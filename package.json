{
  "name": "formzk",
  "version": "1.0.3",
  "license": "MIT",
  "description": "A comprehensive form management library for React, integrating core functionalities with customizable UI components and advanced validation",
  "keywords": [
    "forms",
    "react",
    "form-management",
    "form-builder",
    "input-components",
    "ui-library",
    "react-hook-form",
    "material-ui",
    "validation"
  ],
  "author": "Louis Loo <louiskhenghao@gmail.com> (https://github.com/louiskhenghao)",
  "homepage": "https://github.com/louiskhenghao/formzk#readme",
  "scripts": {
    "start": "nx serve",
    "build": "nx build",
    "dep": "nx dep-graph",
    "format": "prettier --write .",
    "lint": "nx run-many --all --target=lint",
    "example:dev": "yarn start example --port=3333",
    "example:build": "yarn build example",
    "example:run": "yarn start example --prod --port=3333",
    "build:lib:core": "yarn build core",
    "build:lib:mui": "yarn build mui",
    "build:libs": "yarn build:lib:core && yarn build:lib:mui",
    "release": "yarn nx run formzk:version --releaseAs=patch && yarn build:libs",
    "release:minor": "yarn nx run formzk:version --releaseAs=minor && yarn build:libs",
    "release:major": "yarn nx run formzk:version --releaseAs=major && yarn build:libs"
  },
  "private": true,
  "dependencies": {
    "@emotion/react": "^11.11.4",
    "@emotion/styled": "^11.11.5",
    "@hookform/resolvers": "^3.7.0",
    "@mui/icons-material": "^5.15.21",
    "@mui/lab": "^5.0.0-alpha.173",
    "@mui/material": "^5.16.7",
    "@nx/next": "20.8.4",
    "next": "14.2.35",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-error-boundary": "^4.0.13",
    "react-hook-form": "^7.73.1",
    "react-is": "18.3.1",
    "styled-components": "5.3.6",
    "tslib": "^2.8.1",
    "yup": "^1.7.1"
  },
  "devDependencies": {
    "@babel/core": "^7.14.5",
    "@babel/preset-react": "^7.14.5",
    "@emotion/babel-plugin": "11.11.0",
    "@jscutlery/semver": "^3.1.0",
    "@nx/cypress": "20.8.4",
    "@nx/eslint": "20.8.4",
    "@nx/eslint-plugin": "20.8.4",
    "@nx/jest": "20.8.4",
    "@nx/js": "20.8.4",
    "@nx/react": "20.8.4",
    "@nx/rollup": "20.8.4",
    "@nx/workspace": "20.8.4",
    "@rollup/plugin-url": "8.0.2",
    "@svgr/rollup": "8.1.0",
    "@swc/plugin-emotion": "^2.5.67",
    "@testing-library/react": "16.1.0",
    "@types/jest": "29.5.14",
    "@types/lodash": "^4.17.24",
    "@types/node": "18.19.99",
    "@types/react": "18.3.1",
    "@types/react-dom": "18.3.0",
    "@typescript-eslint/eslint-plugin": "7.18.0",
    "@typescript-eslint/parser": "7.18.0",
    "babel-jest": "29.7.0",
    "core-js": "3.36.1",
    "cypress": "14.5.4",
    "eslint": "8.57.1",
    "eslint-config-next": "15.5.9",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-cypress": "2.15.2",
    "eslint-plugin-import": "2.31.0",
    "eslint-plugin-jsx-a11y": "6.10.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "5.0.0",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "jest": "29.7.0",
    "jest-environment-jsdom": "29.7.0",
    "nx": "20.8.4",
    "prettier": "^2.6.2",
    "ts-jest": "^29.4.9",
    "ts-node": "10.9.1",
    "typescript": "~5.9.3"
  }
}
